<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Zayden Gaming — Player HUD</title>
  <meta name="description" content="Live dashboard for Zayden Gaming's YouTube channel — stats, weekly quests, and top missions." />
  <link rel="icon" href="assets/favicon.png" />
  <link rel="stylesheet" href="style.css" />
</head>
<body>

  <header class="hud-header">
    <div class="brand">
      <img src="assets/logo.png" alt="Zayden Gaming logo" />
      <div>
        <div class="brand-title">Zayden Gaming</div>
        <div class="brand-sub">Player HUD · Command Console</div>
      </div>
    </div>
    <div class="sync">
      <span class="live-dot"></span>LAST SYNC · {{ last_updated }}
    </div>
  </header>

  <main>

    <!-- ========================= PLAYER PROFILE ========================= -->
    <section class="panel player-card">
      <div class="avatar-frame">
        <img src="assets/avatar.png" alt="Zayden avatar" />
      </div>
      <div class="player-info">
        <div class="callsign">Callsign</div>
        <div class="name">Zayden</div>
        <div class="tagline">{{ tagline }}</div>
      </div>
      <div class="level-box">
        <div class="level-label">Current Level</div>
        <div class="level-number">{{ level }}</div>
        <div class="xp-bar"><div class="fill" data-target="{{ xp_percent }}" style="width: 0%"></div></div>
        <div class="xp-text">
          <span>{{ subs }} / {{ next_level_subs }} subs</span>
          <span>→ LVL {{ level + 1 }}</span>
        </div>
      </div>
    </section>

    <!-- ========================= STATS HUD ========================= -->
    <section>
      <div class="section-title">Stats HUD</div>
      <div class="stats-grid">
        <div class="stat-tile subs">
          <div class="icon">👥</div>
          <div class="label">Subscribers</div>
          <div class="value" data-count="{{ subs }}">0</div>
          <div class="delta {{ delta_subs_class }}">{{ delta_subs_text }}</div>
        </div>
        <div class="stat-tile views">
          <div class="icon">👁</div>
          <div class="label">Total Views</div>
          <div class="value" data-count="{{ views }}">0</div>
          <div class="delta {{ delta_views_class }}">{{ delta_views_text }}</div>
        </div>
        <div class="stat-tile videos">
          <div class="icon">🎬</div>
          <div class="label">Videos Uploaded</div>
          <div class="value" data-count="{{ video_count }}">0</div>
          <div class="delta {{ delta_videos_class }}">{{ delta_videos_text }}</div>
        </div>
        <div class="stat-tile watch">
          <div class="icon">⏱</div>
          <div class="label">Watch Hours</div>
          <div class="value" data-count="{{ watch_hours }}" data-decimals="1">0</div>
          <div class="delta {{ delta_watch_class }}">{{ delta_watch_text }}</div>
        </div>
      </div>
    </section>

    <!-- ========================= NEXT MILESTONE + PEP TALK ========================= -->
    <section class="milestone-strip">
      <div class="panel milestone-tile">
        <div class="m-label">Next Subscriber Milestone</div>
        <div class="m-headline">
          <span class="m-big">{{ milestones.subs_to_go }}</span>
          <span class="m-rest">to <b>{{ milestones.sub_goal_label }}</b> subs</span>
        </div>
        <div class="m-bar"><div class="m-fill" data-target="{{ milestones.subs_pct }}" style="width:0%"></div></div>
        <div class="m-foot">{{ subs }} / {{ milestones.sub_goal_label }} · {{ milestones.subs_pct }}%</div>
      </div>
      <div class="panel milestone-tile views-tile">
        <div class="m-label">Next Views Milestone</div>
        <div class="m-headline">
          <span class="m-big">{{ milestones.views_to_go }}</span>
          <span class="m-rest">to <b>{{ milestones.view_goal_label }}</b> views</span>
        </div>
        <div class="m-bar"><div class="m-fill alt" data-target="{{ milestones.views_pct }}" style="width:0%"></div></div>
        <div class="m-foot">{{ views }} / {{ milestones.view_goal_label }} · {{ milestones.views_pct }}%</div>
      </div>
      <div class="panel pep-talk">
        <div class="m-label">Coach Pep-Talk</div>
        <div class="pep-text">“{{ pep_talk }}”</div>
        <div class="pep-sig">— Boost</div>
      </div>
    </section>

    <!-- ========================= MONETIZATION PROGRESS ========================= -->
    <section>
      <div class="section-title">Road to Monetization</div>
      <div class="monet-grid">
        <div class="panel monet-card {% if monetization.shorts_tier.unlocked %}unlocked{% endif %}">
          <div class="monet-head">
            <span class="monet-name">{{ monetization.shorts_tier.name }}</span>
            {% if monetization.shorts_tier.unlocked %}
              <span class="monet-badge unlocked">UNLOCKED</span>
            {% else %}
              <span class="monet-badge">{{ monetization.shorts_tier.subs_remaining }} subs to go</span>
            {% endif %}
          </div>
          <div class="monet-bar-row">
            <div class="monet-bar-label">Subscribers</div>
            <div class="monet-bar"><div class="monet-fill" data-target="{{ monetization.shorts_tier.subs_pct }}" style="width:0%"></div></div>
            <div class="monet-num">{{ monetization.shorts_tier.subs_current }} / {{ monetization.shorts_tier.subs_target }}</div>
          </div>
          <div class="monet-note">{{ monetization.shorts_tier.note }}</div>
        </div>

        <div class="panel monet-card {% if monetization.full_ypp.unlocked %}unlocked{% endif %}">
          <div class="monet-head">
            <span class="monet-name">{{ monetization.full_ypp.name }}</span>
            {% if monetization.full_ypp.unlocked %}
              <span class="monet-badge unlocked">UNLOCKED</span>
            {% else %}
              <span class="monet-badge">Big leagues unlock</span>
            {% endif %}
          </div>
          <div class="monet-bar-row">
            <div class="monet-bar-label">Subscribers</div>
            <div class="monet-bar"><div class="monet-fill" data-target="{{ monetization.full_ypp.subs_pct }}" style="width:0%"></div></div>
            <div class="monet-num">{{ monetization.full_ypp.subs_current }} / {{ monetization.full_ypp.subs_target }}</div>
          </div>
          <div class="monet-bar-row">
            <div class="monet-bar-label">Watch Hours</div>
            <div class="monet-bar"><div class="monet-fill alt" data-target="{{ monetization.full_ypp.hours_pct }}" style="width:0%"></div></div>
            <div class="monet-num">{{ monetization.full_ypp.hours_current }} / {{ monetization.full_ypp.hours_target }}</div>
          </div>
          <div class="monet-note">Both bars need to hit 100% to unlock ads on regular videos.</div>
        </div>
      </div>
    </section>

    <!-- ========================= QUESTS ========================= -->
    <section>
      <div class="section-title">This Week's Quests</div>
      <div class="quests">
        {% for quest in quests %}
        <div class="quest">
          <div class="q-head">
            <span class="q-icon">{{ quest.icon }}</span>
            <span>{{ quest.title }}</span>
          </div>
          <div class="q-body">{{ quest.body }}</div>
          <div class="q-why">{{ quest.why }}</div>
        </div>
        {% endfor %}
      </div>
    </section>

    <!-- ========================= TOP MISSION ========================= -->
    {% if top_video %}
    <section class="panel">
      <div class="section-title">Top Mission · Highest Views</div>
      <div class="top-mission">
        <div class="mission-thumb">
          <img src="{{ top_video.thumbnail }}" alt="Top video thumbnail" />
          <a class="play-btn" href="https://www.youtube.com/watch?v={{ top_video.id }}" target="_blank" rel="noopener" title="Play on YouTube">▶</a>
        </div>
        <div class="mission-info">
          <span class="badge">Legendary Drop</span>
          <h3>{{ top_video.title }}</h3>
          <div class="stats">
            <span><b>{{ top_video.views }}</b> views</span>
            <span><b>{{ top_video.likes }}</b> likes</span>
            <span><b>{{ top_video.comments }}</b> comments</span>
          </div>
        </div>
      </div>
    </section>
    {% endif %}

    <!-- ========================= RECENT UPLOADS ========================= -->
    {% if recent_videos %}
    <section>
      <div class="section-title">Recent Uploads</div>
      <div class="uploads-grid">
        {% for v in recent_videos %}
        <a class="upload-card" href="https://www.youtube.com/watch?v={{ v.id }}" target="_blank" rel="noopener">
          <div class="thumb"><img src="{{ v.thumbnail }}" alt="{{ v.title }}" /></div>
          <div class="meta">
            <div class="title">{{ v.title }}</div>
            <div class="views">{{ v.views }} views</div>
          </div>
        </a>
        {% endfor %}
      </div>
    </section>
    {% endif %}

    <!-- ========================= LATEST COMMENTS ========================= -->
    <section>
      <div class="section-title">Latest Comments · Live Fan Mail</div>
      {% if recent_comments %}
      <div class="comments-list">
        {% for c in recent_comments %}
        <a class="comment-card" href="{{ c.url }}" target="_blank" rel="noopener">
          <div class="c-head">
            <span class="c-author">{{ c.author }}</span>
            <span class="c-meta">{{ c.relative }}{% if c.likes %} · 👍 {{ c.likes }}{% endif %}</span>
          </div>
          <div class="c-text">{{ c.text }}</div>
          <div class="c-on">on <b>{{ c.video_title }}</b> <span class="c-arrow">↗</span></div>
        </a>
        {% endfor %}
      </div>
      {% else %}
      <div class="panel comments-empty">
        No new comments yet — keep posting and replying, the fans will come!
      </div>
      {% endif %}
    </section>

    <!-- ========================= ACHIEVEMENTS ========================= -->
    <section>
      <div class="section-title">Achievements</div>
      <div class="achievements">
        {% for a in achievements %}
        <div class="achievement {% if a.unlocked %}unlocked{% endif %}">
          <div class="a-icon">{{ a.icon }}</div>
          <div>
            <div class="a-name">{{ a.name }}</div>
            <div class="a-progress">{{ a.progress }}</div>
          </div>
        </div>
        {% endfor %}
      </div>
    </section>

    <!-- ========================= PARENT PANEL ========================= -->
    <section style="text-align:right;">
      <button class="parent-toggle" id="parent-toggle">🔒 Parent View</button>
      <div class="parent-panel" id="parent-panel">
        <h4>Parent / Coach Notes</h4>
        <div class="metrics">
          <div class="m"><div class="k">Impressions (90d)</div><div class="v">{{ impressions }}</div></div>
          <div class="m"><div class="k">CTR (90d)</div><div class="v">{{ ctr }}%</div></div>
          <div class="m"><div class="k">Avg View Duration</div><div class="v">{{ avd }}</div></div>
          <div class="m"><div class="k">Road to YPP</div><div class="v">{{ ypp_progress }}%</div></div>
        </div>
        <div style="text-align:left;">{{ parent_note | safe }}</div>
      </div>
    </section>

  </main>

  <footer class="hud-footer">
    Generated by <span class="boost">BOOST</span> · Nexus Sub-Agent · Auto-updates Sun · Wed · Fri · Keep playing, Zayden.
  </footer>

  <script src="script.js"></script>
</body>
</html>
